# Keitaro (доступ только через UI -> браузер-автоматизация)
KEITARO_BASE_URL=https://tlgk.host/admin
KEITARO_USERNAME=
KEITARO_PASSWORD=
# 1 = headless (без окна), 0 = показывать браузер (для отладки логина)
KEITARO_HEADLESS=1
# Шаблон приписки версии React в названии VSL-офферов (можно менять v5→v6).
KEITARO_VSL_REACT=ReactJS v5

# --- AdRobot (приём задач) ---
ADROBOT_BASE_URL=https://adrobot.app
ADROBOT_USERNAME=mch
ADROBOT_PASSWORD=
ADROBOT_ME=mch
ADROBOT_MY_ID=649
ADROBOT_STATUS=PENDING,IN_PROCESS
ADROBOT_INCLUDE_ANYONE=true
ADROBOT_EXCLUDE_STATUSES=
# Уведомления из ленты /common/notifications/: на какие смены статуса слать
# (через запятую) и слать ли комментарии к задачам.
ADROBOT_NOTIFY_STATUSES=ACCEPTED
ADROBOT_NOTIFY_COMMENTS=true

# --- AITUNNEL (чат-агент по адаптации, OpenAI-совместимый API) ---
# Ключ из личного кабинета aitunnel.ru (формат sk-aitunnel-...).
AITUNNEL_API_KEY=
AITUNNEL_MODEL=qwen3.7-plus
# Модель для перевода лендов (дёшево/быстро).
TRANSLATE_MODEL=deepseek-v4-flash
# Модель нейро-редактора картинок (правка фото по промпту).
IMAGE_EDIT_MODEL=gpt-image-2
# Токен Dolphin Anty (Settings→API) для импорта прокси из библиотеки аккаунта.
DOLPHIN_API_TOKEN=
AITUNNEL_BASE_URL=https://api.aitunnel.ru/v1

# --- Telegram ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Поллер ---
POLL_INTERVAL=60
NOTIFY_ON_FIRST_RUN=false
